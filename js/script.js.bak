function loadCartFromLocalStorage() {
  const list = document.getElementById("cart-items");
  if (!list) return;
  const cart = readJson(localStorage.getItem(GUEST_CART_KEY), []);
  list.innerHTML = "";
  let total = 0;
  if (!cart.length) {
    list.innerHTML = "<li>Your cart is empty.</li>";
  } else {
    cart.forEach((item, index) => {
      total += toNumber(item.price) * toNumber(item.quantity, 1);
      const li = document.createElement("li");
      li.innerHTML = `
        <div>
          <strong>${escapeHtml(item.product)}</strong>
          <div>${money(item.price)} x ${toNumber(item.quantity, 1)}</div>
        </div>
        <div class="cart-actions"></div>
      `;
      const actions = li.querySelector(".cart-actions");
      const plus = document.createElement("button");
      plus.type = "button";
      plus.textContent = "+";
      plus.addEventListener("click", () => increaseQty(index));
      const minus = document.createElement("button");
      minus.type = "button";
      minus.textContent = "-";
      minus.addEventListener("click", () => decreaseQty(index));
      const remove = document.createElement("button");
      remove.type = "button";
      remove.textContent = "Remove";
      remove.addEventListener("click", () => removeItem(index));
      actions.append(plus, minus, remove);
      list.appendChild(li);
    });
  }
  const totalPrice = document.getElementById("total-price");
  if (totalPrice) totalPrice.textContent = `Total: ${money(total)}`;
  updateCartCount();
}

async function loadCart() {
  if (getToken()) {
    const ok = await loadCartFromApi();
    if (!ok) loadCartFromLocalStorage();
  } else {
    loadCartFromLocalStorage();
  }
}

async function increaseQty(itemRef, currentQuantity, stock, remote = false) {
  if (remote || (typeof itemRef === "number" && getToken())) {
    const nextQuantity = toNumber(currentQuantity, 1) + 1;
    if (stock != null && nextQuantity > toNumber(stock)) {
      notify("Requested quantity exceeds stock");
      return;
    }
    try {
      await apiFetch(`/api/cart/${itemRef}`, { method: "PUT", auth: true, body: { quantity: nextQuantity } });
      await loadCart();
    } catch (error) {
      notify(error.message);
    }
    return;
  }

  const cart = readJson(localStorage.getItem(GUEST_CART_KEY), []);
  if (!cart[itemRef]) return;
  cart[itemRef].quantity += 1;
  localStorage.setItem(GUEST_CART_KEY, JSON.stringify(cart));
  loadCartFromLocalStorage();
}

async function decreaseQty(itemRef, currentQuantity, remote = false) {
  if (remote || (typeof itemRef === "number" && getToken())) {
    const nextQuantity = toNumber(currentQuantity, 1) - 1;
    if (nextQuantity < 1) {
      await removeItem(itemRef, true);
      return;
    }
    try {
      await apiFetch(`/api/cart/${itemRef}`, { method: "PUT", auth: true, body: { quantity: nextQuantity } });
      await loadCart();
    } catch (error) {
      notify(error.message);
    }
    return;
  }

  const cart = readJson(localStorage.getItem(GUEST_CART_KEY), []);
  if (!cart[itemRef]) return;
  if (cart[itemRef].quantity > 1) cart[itemRef].quantity -= 1;
  else cart.splice(itemRef, 1);
  localStorage.setItem(GUEST_CART_KEY, JSON.stringify(cart));
  loadCartFromLocalStorage();
}

async function removeItem(itemRef, remote = false) {
  if (remote || (typeof itemRef === "number" && getToken())) {
    try {
      await apiFetch(`/api/cart/${itemRef}`, { method: "DELETE", auth: true });
      await loadCart();
    } catch (error) {
      notify(error.message);
    }
    return;
  }

  const cart = readJson(localStorage.getItem(GUEST_CART_KEY), []);
  cart.splice(itemRef, 1);
  localStorage.setItem(GUEST_CART_KEY, JSON.stringify(cart));
  loadCartFromLocalStorage();
}

async function clearCart() {
  if (getToken()) {
    try {
      const data = await apiFetch("/api/cart", { auth: true });
      const items = Array.isArray(data.items) ? data.items : [];
      await Promise.all(items.map((item) => apiFetch(`/api/cart/${item.id}`, { method: "DELETE", auth: true })));
    } catch {
      // ignore and fall back to local clear
    }
  }
  localStorage.removeItem(GUEST_CART_KEY);
  await loadCart();
}

async function handleCheckout(event) {
  event.preventDefault();
  if (!getToken()) {
    notify("Please log in before placing an order.");
    window.location.href = "login.html";
    return;
  }
  try {
    const data = await apiFetch("/api/orders", { method: "POST", auth: true });
    ensureMessage(event.currentTarget, data.message || "Order placed successfully", "success");
    await clearCart();
    await loadOrdersSection();
  } catch (error) {
    ensureMessage(event.currentTarget, error.message, "error");
  }
}

function renderOrders(parent, orders) {
  if (!parent) return;
  parent.innerHTML = "";
  if (!orders.length) {
    parent.innerHTML = "<li>No orders found.</li>";
    return;
  }

  orders.forEach((order) => {
    const card = document.createElement("div");
    card.className = "product";
    const items = Array.isArray(order.items) && order.items.length
      ? `<ul>${order.items.map((item) => `<li>${escapeHtml(item.product_name)} x ${escapeHtml(item.quantity)} (${money(item.price)})</li>`).join("")}</ul>`
      : "";
    card.innerHTML = `
      <h3>Order #${escapeHtml(order.id)}</h3>
      <p><strong>Status:</strong> ${escapeHtml(order.status)}</p>
      <p><strong>Total:</strong> ${money(order.total_amount)}</p>
      <p><strong>Created:</strong> ${escapeHtml(order.created_at || "")}</p>
      ${order.buyer_name ? `<p><strong>Buyer:</strong> ${escapeHtml(order.buyer_name)}</p>` : ""}
      ${items}
    `;
    if (getRole() === "Farmer" || getRole() === "Admin") {
      const select = document.createElement("select");
      select.id = `order-status-${order.id}`;
      ["Pending", "Shipped", "Delivered"].forEach((status) => {
        const option = document.createElement("option");
        option.value = status;
        option.textContent = status;
        if (status === order.status) option.selected = true;
        select.appendChild(option);
      });
      const button = document.createElement("button");
      button.type = "button";
      button.textContent = "Update Status";
      button.addEventListener("click", () => updateOrderStatus(order.id));
      card.append(select, button);
    }
    parent.appendChild(card);
  });
}

async function loadOrdersSection() {
  const parent = document.querySelector(".cart-page") || document.querySelector(".checkout") || document.querySelector(".admin-panel");
  if (!parent || !getToken()) return;

  let section = document.getElementById("order-history-section");
  if (!section) {
    section = document.createElement("section");
    section.id = "order-history-section";
    section.innerHTML = "<h2>My Orders</h2><ul id='order-history'></ul>";
    parent.appendChild(section);
  }

  const list = section.querySelector("#order-history");
  try {
    const data = await apiFetch("/api/orders", { auth: true });
    renderOrders(list, Array.isArray(data.orders) ? data.orders : []);
  } catch (error) {
    ensureMessage(section, error.message, "error");
  }
}

async function loadOrders() {
  await loadOrdersSection();
}

async function updateOrderStatus(orderId) {
  const select = document.getElementById(`order-status-${orderId}`);
  if (!select) return;
  try {
    await apiFetch(`/api/orders/${orderId}`, { method: "PUT", auth: true, body: { status: select.value } });
    await loadAdminPanel();
  } catch (error) {
    notify(error.message);
  }
}

async function loadAdminPanel() {
  const adminPanel = document.querySelector(".admin-panel");
  if (!adminPanel) return;
  if (!getToken() || getRole() !== "Admin") {
    ensureMessage(adminPanel, "Admin access required.", "error");
    return;
  }

  try {
    const [stats, users, farms, products, orders, dealers] = await Promise.all([
      apiFetch("/api/admin/stats", { auth: true }),
      apiFetch("/api/admin/users", { auth: true }),
      apiFetch("/api/admin/farms", { auth: true }),
      apiFetch("/api/admin/products", { auth: true }),
      apiFetch("/api/admin/orders", { auth: true }),
      apiFetch("/api/admin/dealers", { auth: true }),
    ]);

    const totalUsers = document.getElementById("totalUsers");
    const totalFarms = document.getElementById("totalFarms");
    if (totalUsers) totalUsers.textContent = stats.total_users ?? 0;
    if (totalFarms) totalFarms.textContent = stats.total_farms ?? 0;

    const usersList = document.getElementById("usersList");
    if (usersList) {
      usersList.innerHTML = "";
      (users.users || []).forEach((user) => {
        const li = document.createElement("li");
        li.innerHTML = `<span>${escapeHtml(user.name)} - ${escapeHtml(user.role)}</span>`;
        const button = document.createElement("button");
        button.type = "button";
        button.textContent = "Delete";
        button.addEventListener("click", async () => {
          if (!window.confirm(`Delete ${user.name}?`)) return;
          try {
            await apiFetch(`/api/admin/users/${user.id}`, { method: "DELETE", auth: true });
            await loadAdminPanel();
          } catch (error) {
            notify(error.message);
          }
        });
        li.appendChild(button);
        usersList.appendChild(li);
      });
    }

    const farmsList = document.getElementById("farmsList");
    if (farmsList) {
      farmsList.innerHTML = "";
      (farms.farms || []).forEach((farm) => {
        const li = document.createElement("li");
        li.textContent = `${farm.farm_name} - ${farm.location}`;
        farmsList.appendChild(li);
      });
    }

    let summary = document.getElementById("admin-summary");
    if (!summary) {
      summary = document.createElement("section");
      summary.id = "admin-summary";
      adminPanel.appendChild(summary);
    }

    summary.innerHTML = `
      <h2>Products</h2>
      <ul>${(products.products || []).slice(0, 8).map((product) => `<li>${escapeHtml(product.product_name)} - ${escapeHtml(product.farm_name || "")}</li>`).join("") || "<li>No products</li>"}</ul>
      <h2>Orders</h2>
      <ul>${(orders.orders || []).slice(0, 8).map((order) => `<li>#${escapeHtml(order.id)} - ${money(order.total_amount)} - ${escapeHtml(order.status)} <button type='button' onclick='deleteOrder(${order.id})'>Delete</button></li>`).join("") || "<li>No orders</li>"}</ul>
      <h2>Dealers</h2>
      <ul>${(dealers.dealers || []).slice(0, 8).map((dealer) => `<li>${escapeHtml(dealer.dealer_name)} - ${escapeHtml(dealer.shop_name)} - ${escapeHtml(dealer.location)}</li>`).join("") || "<li>No dealers</li>"}</ul>
    `;
  } catch (error) {
    ensureMessage(adminPanel, error.message, "error");
  }
}

async function deleteUser(userId, userName) {
  if (!window.confirm(`Delete ${userName || "this user"}?`)) return;
  try {
    await apiFetch(`/api/admin/users/${userId}`, { method: "DELETE", auth: true });
    await loadAdminPanel();
  } catch (error) {
    notify(error.message);
  }
}

async function deleteOrder(orderId, orderName) {
  if (!window.confirm(`Delete order ${orderName || orderId}?`)) return;
  try {
    await apiFetch(`/api/admin/orders/${orderId}`, { method: "DELETE", auth: true });
    await loadAdminPanel();
  } catch (error) {
    notify(error.message);
  }
}

function ensureManageFarmInputs() {
  const form = document.querySelector(".dashboard");
  if (!form || document.getElementById("productCategory")) return;

  const productName = document.getElementById("productName");
  const category = document.createElement("input");
  category.type = "text";
  category.id = "productCategory";
  category.placeholder = "Category";
  const stock = document.createElement("input");
  stock.type = "number";
  stock.id = "productStock";
  stock.placeholder = "Stock";

  if (productName && productName.parentNode) {
    productName.insertAdjacentElement("afterend", category);
    category.insertAdjacentElement("afterend", stock);
  } else {
    form.append(category, stock);
  }
}

async function addToCart(productOrId, secondArg, quantity = 1, productMeta = null) {
  const productType = secondArg === "Farm" || secondArg === "Pesticide" ? secondArg : null;

  if (getToken() && productType) {
    try {
      const data = await apiFetch("/api/cart", {
        method: "POST",
        auth: true,
        body: {
          product_id: productOrId,
          product_type: productType,
          quantity,
        },
      });
      updateCartCount();
      notify(data.message || `${productMeta?.product_name || "Item"} added to cart`);
      return;
    } catch (error) {
      notify(error.message);
      return;
    }
  }

  const cart = readJson(localStorage.getItem(GUEST_CART_KEY), []);
  const productName = productMeta?.product_name || String(productOrId || "Item");
  const price = productType ? toNumber(productMeta?.price) : toNumber(secondArg);
  const existing = cart.find((item) => item.product === productName);
  if (existing) existing.quantity += quantity;
  else cart.push({ product: productName, price, quantity });
  localStorage.setItem(GUEST_CART_KEY, JSON.stringify(cart));
  updateCartCount();
  notify(`${productName} added to cart`);
}

async function loadCartFromApi() {
  const list = document.getElementById("cart-items");
  if (!list) return false;
  try {
    const data = await apiFetch("/api/cart", { auth: true });
    const items = Array.isArray(data.items) ? data.items : [];
    list.innerHTML = "";
    if (!items.length) {
      list.innerHTML = "<li>Your cart is empty.</li>";
    } else {
      items.forEach((item) => list.appendChild(renderCartItem(item, item.id, true)));
    }
    const totalPrice = document.getElementById("total-price");
    if (totalPrice) totalPrice.textContent = `Total: ${money(data.total_amount || 0)}`;
    updateCartCount(items);
    return true;
  } catch (error) {
    ensureMessage(list.parentElement || list, error.message, "error");
    return false;
  }
}

function loadCartFromLocalStorage() {
  const list = document.getElementById("cart-items");
  if (!list) return;
  const cart = readJson(localStorage.getItem(GUEST_CART_KEY), []);
  list.innerHTML = "";
  let total = 0;
  if (!cart.length) {
    list.innerHTML = "<li>Your cart is empty.</li>";
  } else {
    cart.forEach((item, index) => {
      total += toNumber(item.price) * toNumber(item.quantity, 1);
      const li = document.createElement("li");
      li.innerHTML = `
        <div>
          <strong>${escapeHtml(item.product)}</strong>
          <div>${money(item.price)} x ${toNumber(item.quantity, 1)}</div>
        </div>
        <div class="cart-actions"></div>
      `;
      const actions = li.querySelector(".cart-actions");
      const plus = document.createElement("button");
      plus.type = "button";
      plus.textContent = "+";
      plus.addEventListener("click", () => increaseQty(index));
      const minus = document.createElement("button");
      minus.type = "button";
      minus.textContent = "-";
      minus.addEventListener("click", () => decreaseQty(index));
      const remove = document.createElement("button");
      remove.type = "button";
      remove.textContent = "Remove";
      remove.addEventListener("click", () => removeItem(index));
      actions.append(plus, minus, remove);
      list.appendChild(li);
    });
  }
  const totalPrice = document.getElementById("total-price");
  if (totalPrice) totalPrice.textContent = `Total: ${money(total)}`;
  updateCartCount();
}

async function loadCart() {
  if (getToken()) {
    const ok = await loadCartFromApi();
    if (!ok) loadCartFromLocalStorage();
  } else {
    loadCartFromLocalStorage();
  }
}

