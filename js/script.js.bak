    const items = Array.isArray(order.items) && order.items.length
      ? `<ul>${order.items.map((item) => `<li>${escapeHtml(item.product_name)} x ${escapeHtml(item.quantity)} (${money(item.price)})</li>`).join("")}</ul>`
